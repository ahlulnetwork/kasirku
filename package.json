{
  "name": "kasirku",
  "version": "1.6.4",
  "description": "Aplikasi Kasir Desktop - KasirKu",
  "author": "PT. Java Inovasi Digital",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:start": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && npm run obfuscate && electron-builder",
    "electron:build:win": "npm run build && npm run obfuscate && electron-builder --win",
    "obfuscate": "javascript-obfuscator electron --output .tmp-electron --string-array true --string-array-encoding rc4 --string-array-threshold 1 --identifier-names-generator hexadecimal --split-strings true --dead-code-injection true --compact true",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "archiver": "^7.0.0",
    "better-sqlite3": "^11.0.0",
    "extract-zip": "^2.0.1",
    "jsbarcode": "^3.11.6",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2"
  },
  "devDependencies": {
    "@vicons/ionicons5": "^0.12.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "javascript-obfuscator": "^5.4.1",
    "naive-ui": "^2.38.0",
    "pinia": "^2.1.0",
    "vite": "^5.4.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.kasirku.app",
    "productName": "KasirKu",
    "directories": {
      "output": "dist-electron"
    },
    "npmRebuild": false,
    "files": [
      "**/*",
      "!electron/**",
      {
        "from": ".tmp-electron",
        "to": "electron",
        "filter": [
          "**/*"
        ]
      },
      "!src/**",
      "!public/**",
      "!data/**",
      "!.github/**",
      "!DOKUMENTASI.md",
      "!logo.png",
      "!logo.ico",
      "!vite.config.js",
      "!obfuscation-test.js",
      "!test-path.js",
      "!test-wmic.js"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "extraResources": [
      {
        "from": "data/",
        "to": "data/",
        "filter": [
          ".gitkeep"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    }
  }
}
